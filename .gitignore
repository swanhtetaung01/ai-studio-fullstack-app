### ===== BACKEND (Spring Boot / Maven) =====
backend/target/
backend/*.log
backend/HELP.md

# Maven wrapper (optional to ignore)
backend/.mvn/wrapper/maven-wrapper.jar

# Allow target inside src (rare cases)
!backend/**/src/main/**/target/
!backend/**/src/test/**/target/


### ===== FRONTEND (React / Vite) =====
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.env

# React / Node extras
frontend/.pnp
frontend/.pnp.js
frontend/coverage

# Logs
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

# Environment files
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local


### ===== IDE FILES =====
# IntelliJ
.idea/
*.iws
*.iml
*.ipr

# VS Code
.vscode/

# Eclipse / STS
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/


### ===== OS FILES =====
.DS_Store
Thumbs.db


### ===== GLOBAL ENV / SECRETS =====
.env


### ===== SPRING BOOT CONFIG (VERY IMPORTANT) =====
backend/src/main/resources/application.properties
backend/src/main/resources/application-*.properties